{
  "name": "reservation-management-system",
  "version": "1.0.0",
  "description": "Reservation Management System - Thrivelab Technical Challenge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm infra:up && pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build:all": "pnpm --filter \"./apps/*\" build",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:localstack:up": "docker compose --profile infra up -d localstack",
    "infra:tf:init": "docker compose --profile infra run --rm terraform init",
    "infra:tf:plan": "docker compose --profile infra run --rm terraform plan",
    "infra:tf:apply": "docker compose --profile infra run --rm terraform apply",
    "infra:tf:destroy": "docker compose --profile infra run --rm terraform destroy",
    "db:migrate:run:docker": "docker compose run --rm migrate",
    "db:migrate:revert:docker": "docker compose run --rm migrate-revert",
    "db:migrate:generate": "pnpm --filter backend migration:generate",
    "db:migrate:run": "pnpm --filter backend migration:run",
    "db:migrate:revert": "pnpm --filter backend migration:revert",
    "test": "pnpm --filter backend test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.6.0",
      "onFail": "download"
    }
  }
}
